<% layout("/layouts/boilerplate") %> 

<div id="filters">
  <div class="filters-left">

    <a href="/listings?category=Trending&search=<%= search || '' %>" 
       class="filter <%= category === 'Trending' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </a>

    <a href="/listings?category=Rooms&search=<%= search || '' %>" 
       class="filter <%= category === 'Rooms' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </a>

    <a href="/listings?category=Mountains&search=<%= search || '' %>" 
       class="filter <%= category === 'Mountains' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </a>

    <a href="/listings?category=Castles&search=<%= search || '' %>" 
       class="filter <%= category === 'Castles' ? 'active-filter' : '' %>">
      <div><i class="fa-brands fa-fort-awesome"></i></div>
      <p>Castles</p>
    </a>

    <a href="/listings?category=Amazing%20pools&search=<%= search || '' %>" 
       class="filter <%= category === 'Amazing pools' ? 'active-filter' : '' %>">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing pools</p>
    </a>

  </div>

  <div class="filters-right">
    <div class="tax-toggle">
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">
          Display total after taxes
        </label>
      </div>
    </div>
  </div>
</div>


<!-- LISTINGS -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <% for (let listing of allListings) { %>

    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card col listing-card">
        <div class="card h-100 border-0">

          <img 
            src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1499793983690-e29da59ef1c2' %>" 
            class="card-img-top" 
            alt="listing image" 
            style="height:20rem"
          >

          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>

              <!-- NORMAL PRICE -->
              <span class="base-price">
                ₹ <%= listing.price.toLocaleString("en-IN") %>
              </span>

              <!-- TAX PRICE -->
              <span class="tax-price" style="display:none;">
                ₹ <%= Math.round(listing.price * 1.18).toLocaleString("en-IN") %>
              </span>

              /night
              <span class="tax-info"> (incl. 18% GST)</span>
            </p>
          </div>

        </div>
      </div>
    </a>

  <% } %>
</div>


<!-- SCRIPT -->
<script>
  const taxSwitch = document.getElementById("switchCheckDefault");

  if (taxSwitch) {
    taxSwitch.addEventListener("change", () => {
      const taxInfo = document.getElementsByClassName("tax-info");
      const basePrices = document.getElementsByClassName("base-price");
      const taxPrices = document.getElementsByClassName("tax-price");

      for (let i = 0; i < taxInfo.length; i++) {
        if (taxSwitch.checked) {
          taxInfo[i].style.display = "inline";
          basePrices[i].style.display = "none";
          taxPrices[i].style.display = "inline";
        } else {
          taxInfo[i].style.display = "none";
          basePrices[i].style.display = "inline";
          taxPrices[i].style.display = "none";
        }
      }
    });
  }
</script>
